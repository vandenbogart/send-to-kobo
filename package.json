{
  "name": "send-to-kobo",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker for sending ebooks from a browser to an e-reader browser.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "wrangler types --experimental-include-runtime false"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "wrangler": "^4.21.2"
  }
}
